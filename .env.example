# Max — Agent Management Platform
# Copy this to .env and fill in your values

# Secret key for Flask sessions
MAX_SECRET_KEY=change-this-to-something-random

# Claude CLI path (usually auto-detected)
# CLAUDE_CLI_PATH=~/.local/bin/claude

# Project directories — where your projects live
# Comma-separated list of name:path pairs
# MAX_PROJECT_LOCATIONS=local:~/Projects,work:~/Work/Projects

# VPS Configuration (optional)
# VPS_HOST=your-vps-ip
# VPS_PORT=22
# VPS_USER=root
# VPS_KEY_PATH=~/.ssh/id_rsa
# VPS_POSTGRES_DSN=postgresql://user:pass@localhost/max_db

# Discord Bot (optional)
# DISCORD_BOT_TOKEN=your-bot-token
# DISCORD_APP_ID=your-app-id

# Port (default: 8086 — Agent 86's number)
# MAX_PORT=8086
